# Copy this file to `.env` and fill the values for local Google/Firebase sign-in.
# Keep `.env` out of version control.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Debug/QA only. Shows an email/password panel below the Google button.
ONEWALLET_ENABLE_EMAIL_PASSWORD_AUTH=false
ONEWALLET_QA_EMAIL=
ONEWALLET_QA_PASSWORD=

# Optional Firebase emulator settings. Keep false for production Firebase testing.
FIREBASE_USE_EMULATOR=false
FIREBASE_EMULATOR_HOST=10.0.2.2
FIREBASE_AUTH_EMULATOR_PORT=9099
FIREBASE_FIRESTORE_EMULATOR_PORT=8080
