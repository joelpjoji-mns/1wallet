{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      }
    },
    "simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "beta",
      "autoIncrement": false,
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "distribution": "store",
      "channel": "stable",
      "autoIncrement": false,
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {}
    },
    "production": {
      "ios": {}
    }
  }
}