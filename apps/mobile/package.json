{
  "name": "@1wallet/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "android:hot": "node ./scripts/android-hot.mjs start",
    "android:hot:install": "node ./scripts/android-hot.mjs install",
    "android:hot:launch": "node ./scripts/android-hot.mjs launch",
    "android:hot:setup": "node ./scripts/android-hot.mjs setup",
    "android:release": "node ./scripts/android-release.mjs",
    "android:release:universal": "node ./scripts/android-release.mjs --universal",
    "android:release:universal:all": "node ./scripts/android-release.mjs --universal --all-abis",
    "android:release:aab": "node ./scripts/android-release.mjs --bundle",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios",
    "ios:simulator": "node ./scripts/ios-release.mjs --profile simulator --local",
    "ios:release": "node ./scripts/ios-release.mjs --profile production",
    "ios:release:testflight": "node ./scripts/ios-release.mjs --profile preview --submit",
    "ios:submit": "node ./scripts/ios-release.mjs --submit-only --profile production",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "lint": "expo lint . && node ../../node_modules/typescript/bin/tsc --noEmit",
    "clean": "node ../../node_modules/rimraf/dist/esm/bin.mjs .expo .turbo"
  },
  "dependencies": {
    "@1wallet/config": "workspace:*",
    "@1wallet/domain": "workspace:*",
    "@1wallet/ledger": "workspace:*",
    "@1wallet/state": "workspace:*",
    "@1wallet/ui": "workspace:*",
    "@1wallet/validation": "workspace:*",
    "@babel/runtime": "^7.29.7",
    "@expo/metro-runtime": "~56.0.13",
    "@expo/vector-icons": "^15.1.1",
    "@firebase/auth": "1.13.2",
    "@pchmn/expo-material3-theme": "^1.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.90.12",
    "expo": "~56.0.8",
    "expo-auth-session": "~56.0.13",
    "expo-constants": "~56.0.16",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-image-picker": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.15",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-drawer-layout": "4.2.4",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-get-sms-android": "^2.1.0",
    "react-native-pager-view": "8.0.1",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-tab-view": "^4.3.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native/metro-config": "0.85.3",
    "@testing-library/dom": "^10.4.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~56.0.4",
    "react-dom": "19.2.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
