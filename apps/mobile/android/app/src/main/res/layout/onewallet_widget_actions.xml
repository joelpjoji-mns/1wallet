<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_actions_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="14dp"
  android:background="@drawable/onewallet_widget_background">

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="1wallet actions"
    android:textColor="#315DA8"
    android:textSize="13sp"
    android:textStyle="bold"/>

  <TextView
    android:id="@+id/widget_actions_balance"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="Open 1wallet"
    android:textColor="#1D1B20"
    android:textSize="18sp"
    android:textStyle="bold"/>

  <TextView
    android:id="@+id/widget_actions_rules"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="No active rules"
    android:textColor="#5F5A66"
    android:textSize="12sp"/>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="bottom"
    android:orientation="horizontal">
    <TextView
      android:id="@+id/widget_action_add"
      android:layout_width="0dp"
      android:layout_height="40dp"
      android:layout_marginEnd="6dp"
      android:layout_weight="1"
      android:background="@drawable/onewallet_widget_action_background"
      android:gravity="center"
      android:text="Add"
      android:textColor="#21005D"
      android:textSize="13sp"
      android:textStyle="bold"/>
    <TextView
      android:id="@+id/widget_action_recurring"
      android:layout_width="0dp"
      android:layout_height="40dp"
      android:layout_marginHorizontal="3dp"
      android:layout_weight="1"
      android:background="@drawable/onewallet_widget_action_background"
      android:gravity="center"
      android:text="Plan"
      android:textColor="#21005D"
      android:textSize="13sp"
      android:textStyle="bold"/>
    <TextView
      android:id="@+id/widget_action_rules"
      android:layout_width="0dp"
      android:layout_height="40dp"
      android:layout_marginStart="6dp"
      android:layout_weight="1"
      android:background="@drawable/onewallet_widget_action_background"
      android:gravity="center"
      android:text="Rules"
      android:textColor="#21005D"
      android:textSize="13sp"
      android:textStyle="bold"/>
  </LinearLayout>
</LinearLayout>
