{
  "expo": {
    "name": "1wallet",
    "slug": "1wallet",
    "version": "1.6.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "scheme": "onewallet",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joelpjoji.one.wallet",
      "buildNumber": "1060000",
      "deploymentTarget": "16.4",
      "usesIcloudStorage": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow 1wallet to scan receipt and bill photos.",
        "NSPhotoLibraryUsageDescription": "Allow 1wallet to choose receipt and bill images from your photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow 1wallet to save exported backup files when you choose to share them.",
        "NSUserNotificationsUsageDescription": "Allow 1wallet to show review, reminder, update, and wallet alerts."
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.joelpjoji.one.wallet"
        ]
      }
    },
    "android": {
      "package": "com.joelpjoji.one.wallet",
      "permissions": [
        "CAMERA",
        "READ_SMS",
        "RECEIVE_SMS",
        "WAKE_LOCK",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VISUAL_USER_SELECTED",
        "READ_EXTERNAL_STORAGE",
        "REQUEST_INSTALL_PACKAGES",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#315DA8"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow 1wallet to scan receipt and bill photos.",
          "photosPermission": "Allow 1wallet to choose receipt and bill images from your photos."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter-Regular.ttf",
            "./assets/fonts/Inter-Medium.ttf",
            "./assets/fonts/Inter-SemiBold.ttf",
            "./assets/fonts/Inter-Bold.ttf",
            "./assets/fonts/RobotoMono-Regular.ttf",
            "./assets/fonts/RobotoMono-Medium.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash-native.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-updates",
      "expo-sharing"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
